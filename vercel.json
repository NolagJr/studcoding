{
    "version": 2,
    "builds": [
      { "src": "*.html", "use": "@vercel/static" }
    ],
    "routes": [
      { "src": "/", "dest": "/index.html" },
      { "src": "/(.*\\.html)", "dest": "/$1" },
      { "src": "/(.*\\.css)", "dest": "/$1" },
      { "src": "/(.*\\.js)", "dest": "/$1" },
      { "src": "/(.*\\.lua)", "dest": "/$1" },
      { "src": "/(.*\\.png)", "dest": "/$1" },
      { "src": "/(.*)", "dest": "/$1.html" }
    ]
  }